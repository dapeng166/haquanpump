# ----------------------------------------------------------------------
# Haquan Pump — environment variables
# Copy this file to `.env.local` and fill in the values, then restart dev.
# ----------------------------------------------------------------------

# WordPress REST API base URL (no trailing slash).
# The backend already exists at https://haquanpump.com/cms
NEXT_PUBLIC_WP_API_URL=https://haquanpump.com/cms/wp-json

# Public site URL — used for canonical tags, sitemap.xml and robots.txt.
NEXT_PUBLIC_SITE_URL=https://www.haquanpump.com

# Content source:
#   merge (default) — full curated catalogue + any extra live CMS items
#                     (curated entries authoritative; complete site for preview)
#   live            — only WordPress (falls back to seed if CMS is empty)
#   seed            — curated catalogue only (offline demo)
# Switch to "live" once your WordPress catalogue is fully populated.
NEXT_PUBLIC_CONTENT_MODE=merge

# ---- Contact form email delivery (optional but recommended) ----
# The inquiry API route (app/api/inquiry/route.ts) will send mail through
# Resend when this key is present. Get one free at https://resend.com
RESEND_API_KEY=
# Where inquiries are delivered:
INQUIRY_TO_EMAIL=sales@haquanpump.com
# Verified sender (must be a domain you verified in Resend):
INQUIRY_FROM_EMAIL=sales@haquanpump.com
